---
import Layout from "../layouts/Layout.astro";
import { InteractiveCard } from "../components/InteractiveCard";
import { CodeBlock } from "../components/CodeBlock";
import { DynamicInstallButton } from "../components/DynamicInstallButton";
import { getAllRules } from "../lib/rules";

const rules = await getAllRules();
---

<Layout title="Axiom" description="The immutable system of truth for AI agent style guides and coding standards.">

  <!-- Hero -->
  <section class="relative min-h-[85vh] flex items-center justify-center overflow-x-clip overflow-y-visible">
    <div class="absolute top-1/3 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] rounded-full bg-zinc-500/[0.03] blur-[100px] pointer-events-none"></div>

    <div class="relative max-w-7xl mx-auto px-6 text-center">
      <h1 class="animate-fade-in-up-delay-1 text-7xl sm:text-8xl md:text-[10rem] font-black text-zinc-100 tracking-[-0.06em] leading-[0.8] mb-6">
        AXIOM
      </h1>

      <p class="animate-fade-in-up-delay-2 text-base sm:text-lg text-zinc-500 max-w-lg mx-auto leading-relaxed mb-10">
        Style guides and coding standards for AI agents.
        <span class="text-zinc-300">One schema. Every platform. Zero ambiguity.</span>
      </p>

      <div class="animate-fade-in-up-delay-3 flex flex-col sm:flex-row items-center justify-center gap-3">
        <DynamicInstallButton client:load />
      </div>
    </div>
  </section>

  <!-- Rules Grid (16 ecosystems) -->
  <section class="max-w-7xl mx-auto px-6 py-20">
    <div class="flex items-end justify-between mb-10">
      <div>
        <h2 class="text-2xl sm:text-3xl font-black text-zinc-100 tracking-[-0.03em] mb-2">
          Rules
        </h2>
        <p class="text-zinc-500 text-sm">
          {rules.length} production-grade style guides across {new Set(rules.map((r) => r.ecosystem)).size} ecosystems.
        </p>
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3">
      {rules.slice(0, 8).map((rule) => (
        <InteractiveCard
          id={rule.id}
          name={rule.name}
          ecosystem={rule.ecosystem}
          version={rule.version}
          philosophy={rule.human_view.philosophy}
          extensions={rule.cli_target.extensions}
        />
      ))}
    </div>

    {rules.length > 8 && (
      <div class="mt-6 text-center">
        <a
          href="/rules"
          class="group relative z-0 overflow-hidden inline-flex items-center gap-2 px-6 py-2.5 ring-1 ring-zinc-800 bg-zinc-950/50 backdrop-blur-md text-zinc-400 font-semibold text-sm tracking-tight transition-all duration-500 rounded-lg hover:text-zinc-900 hover:ring-white"
        >
          <div class="absolute inset-0 bg-white origin-right scale-x-0 transition-transform duration-500 ease-[cubic-bezier(0.19,1,0.22,1)] group-hover:scale-x-100 -z-10"></div>
          View all rules
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-4 -rotate-45 transition-all duration-500 ease-[cubic-bezier(0.19,1,0.22,1)] group-hover:rotate-0 group-hover:translate-x-0.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    )}
  </section>



</Layout>
